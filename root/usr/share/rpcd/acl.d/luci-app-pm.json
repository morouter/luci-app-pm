{
  "luci-app-pm": {
    "description": "ACL for luci-app-pm",
    "read": {
      "ubus": {
        "session": ["access", "login"],
        "system": ["info"]
      }
    },
    "write": {
      "ubus": {
        "system": ["reboot"]
      },
      "file": {
        "/sbin/poweroff": ["exec"]
      }
    }
  }
}
