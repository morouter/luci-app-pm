{
	"luci-app-powermanager": {
		"description": "ACL file for luci-app-powermanager",
		"read": {
			"ubus": {
				"session": [ "access", "login" ],
				"system": [ "info" ]
			},
			"file": {
				"/sbin/poweroff": [ "exec" ]
			}
		},
		"write": {
			"ubus": {
				"system": [ "reboot" ]
			},
			"file": {
				"/sbin/poweroff": [ "exec" ]
			}
		}
	}
}
